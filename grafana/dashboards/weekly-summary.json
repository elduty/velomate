{
  "uid": "veloai-weekly",
  "title": "Activity Summary",
  "tags": [
    "veloai"
  ],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-12w",
    "to": "now"
  },
  "refresh": "1h",
  "panels": [
    {
      "id": 1,
      "title": "Distance (km)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT \n  date_trunc('day', date)::date AS time,\n  CASE WHEN is_indoor THEN 'Indoor' ELSE 'Outdoor' END AS category,\n  ROUND((SUM(distance_m) / 1000.0)::numeric, 1) AS \"km\"\nFROM activities\nWHERE $__timeFilter(date) AND distance_m > 0\nGROUP BY 1, 2\nORDER BY 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 2,
      "title": "Elevation (m)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT \n  date_trunc('day', date)::date AS time,\n  CASE WHEN is_indoor THEN 'Indoor' ELSE 'Outdoor' END AS category,\n  ROUND((SUM(distance_m) / 1000.0)::numeric, 1) AS \"km\"\nFROM activities\nWHERE $__timeFilter(date) AND distance_m > 0\nGROUP BY 1, 2\nORDER BY 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 3,
      "title": "Calories",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  date_trunc('day', date)::date AS time,\n  CASE WHEN is_indoor THEN 'Indoor' ELSE 'Outdoor' END AS category,\n  SUM(calories) AS \"kcal\"\nFROM activities\nWHERE $__timeFilter(date) AND calories IS NOT NULL\nGROUP BY 1, 2\nORDER BY 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}