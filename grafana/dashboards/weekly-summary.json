{
  "uid": "veloai-weekly",
  "title": "Activity Summary",
  "tags": [
    "veloai"
  ],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-12w",
    "to": "now"
  },
  "refresh": "1h",
  "panels": [
    {
      "id": 1,
      "title": "Distance (km)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, ROUND((SUM(distance_m)/1000.0)::numeric,1) AS \"Outdoor km\" FROM activities WHERE $__timeFilter(date) AND distance_m > 0 AND is_indoor = false GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, ROUND((SUM(distance_m)/1000.0)::numeric,1) AS \"Indoor km\" FROM activities WHERE $__timeFilter(date) AND distance_m > 0 AND is_indoor = true GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 2,
      "title": "Elevation (m)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, ROUND(SUM(elevation_m)::numeric,0) AS \"Outdoor m\" FROM activities WHERE $__timeFilter(date) AND distance_m > 0 AND is_indoor = false GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, ROUND(SUM(elevation_m)::numeric,0) AS \"Indoor m\" FROM activities WHERE $__timeFilter(date) AND distance_m > 0 AND is_indoor = true GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 3,
      "title": "Calories",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, SUM(calories) AS \"Outdoor kcal\" FROM activities WHERE $__timeFilter(date) AND calories IS NOT NULL AND is_indoor = false GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, SUM(calories) AS \"Indoor kcal\" FROM activities WHERE $__timeFilter(date) AND calories IS NOT NULL AND is_indoor = true GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}