{
  "uid": "veloai-weekly",
  "title": "Weekly Summary",
  "tags": ["veloai"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-12w",
    "to": "now"
  },
  "refresh": "1h",
  "panels": [
    {
      "id": 1,
      "title": "Weekly Distance (km)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('week', date)::date AS time, ROUND(SUM(distance_m) / 1000.0, 1) AS \"Distance (km)\" FROM activities WHERE date >= NOW() - INTERVAL '12 weeks' GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "km",
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "id": 2,
      "title": "Weekly Elevation (m)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('week', date)::date AS time, ROUND(SUM(elevation_m)::numeric, 0) AS \"Elevation (m)\" FROM activities WHERE date >= NOW() - INTERVAL '12 weeks' GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "id": 3,
      "title": "Weekly Calories",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('week', date)::date AS time, SUM(calories) AS \"Calories\" FROM activities WHERE date >= NOW() - INTERVAL '12 weeks' AND calories IS NOT NULL GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
