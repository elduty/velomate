          "rawSql": "SELECT gs.day AS time, ROUND(SUM(a.elevation_m)::numeric,0) AS \"Outdoor m\"\nFROM generate_series(date_trunc('day',$__timeFrom()::timestamptz), date_trunc('day',$__timeTo()::timestamptz),'1 day'::interval) gs(day)\nLEFT JOIN activities a ON date_trunc('day',a.date)=gs.day AND a.elevation_m>0 AND a.is_indoor=false\nGROUP BY 1 ORDER BY 1;",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "format": "time_series"
        },
        {
          "rawSql": "SELECT gs.day AS time, ROUND(SUM(a.elevation_m)::numeric,0) AS \"Indoor m\"\nFROM generate_series(date_trunc('day',$__timeFrom()::timestamptz), date_trunc('day',$__timeTo()::timestamptz),'1 day'::interval) gs(day)\nLEFT JOIN activities a ON date_trunc('day',a.date)=gs.day AND a.elevation_m>0 AND a.is_indoor=true\nGROUP BY 1 ORDER BY 1;",
          "refId": "B",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "barWidthFactor": 0.8
