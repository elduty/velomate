        }
      }
    },
    {
      "id": 8,
      "title": "Calories",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT gs.day AS time, ROUND(SUM(a.calories)::numeric,0) AS \"Outdoor kcal\"\nFROM generate_series(date_trunc('day',$__timeFrom()::timestamptz), date_trunc('day',$__timeTo()::timestamptz),'1 day'::interval) gs(day)\nLEFT JOIN activities a ON date_trunc('day',a.date)=gs.day AND a.calories>0 AND a.is_indoor=false\nGROUP BY 1 ORDER BY 1;",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "format": "time_series"
        },
        {
          "rawSql": "SELECT gs.day AS time, ROUND(SUM(a.calories)::numeric,0) AS \"Indoor kcal\"\nFROM generate_series(date_trunc('day',$__timeFrom()::timestamptz), date_trunc('day',$__timeTo()::timestamptz),'1 day'::interval) gs(day)\nLEFT JOIN activities a ON date_trunc('day',a.date)=gs.day AND a.calories>0 AND a.is_indoor=true\nGROUP BY 1 ORDER BY 1;",
          "refId": "B",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
