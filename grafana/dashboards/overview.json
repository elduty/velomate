    },
    {
      "id": 5,
      "title": "Current Form (TSB)",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT tsb AS \"TSB\" FROM athlete_stats ORDER BY date DESC LIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": -40,
          "max": 40,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": -10
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "super-light-green",
                "value": 15
              },
              {
                "color": "blue",
                "value": 25
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "Distance (km)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT gs.day AS time, ROUND((SUM(a.distance_m)/1000.0)::numeric,1) AS \"Outdoor km\"\nFROM generate_series(date_trunc('day',$__timeFrom()::timestamptz), date_trunc('day',$__timeTo()::timestamptz),'1 day'::interval) gs(day)\nLEFT JOIN activities a ON date_trunc('day',a.date)=gs.day AND a.distance_m>0 AND a.is_indoor=false\nGROUP BY 1 ORDER BY 1;",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "format": "time_series"
        },
        {
          "rawSql": "SELECT gs.day AS time, ROUND((SUM(a.distance_m)/1000.0)::numeric,1) AS \"Indoor km\"\nFROM generate_series(date_trunc('day',$__timeFrom()::timestamptz), date_trunc('day',$__timeTo()::timestamptz),'1 day'::interval) gs(day)\nLEFT JOIN activities a ON date_trunc('day',a.date)=gs.day AND a.distance_m>0 AND a.is_indoor=true\nGROUP BY 1 ORDER BY 1;",
          "refId": "B",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "barWidthFactor": 0.8
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 7,
      "title": "Elevation (m)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
