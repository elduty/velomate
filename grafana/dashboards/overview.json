      "targets": [{ "rawSql": "SELECT gs AS \"time\", COALESCE(ROUND(SUM(a.tss)::numeric, 0), 0) AS \"TSS\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.tss IS NOT NULL GROUP BY gs ORDER BY gs;", "format": "time_series", "refId": "A" }],
