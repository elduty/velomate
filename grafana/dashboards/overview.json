{
  "uid": "veloai-overview",
  "title": "Overview",
  "tags": [
    "veloai"
  ],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "title": "Rides",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"rides\" FROM activities WHERE $__timeFilter(date);",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 3
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Distance",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND((SUM(distance_m) / 1000.0)::numeric, 1) AS \"km\" FROM activities WHERE $__timeFilter(date) AND distance_m > 0;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Elevation",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM(elevation_m)::numeric, 0) AS \"meters\" FROM activities WHERE $__timeFilter(date) AND distance_m > 0;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "green",
                "value": 1000
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Current Form (TSB)",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT tsb AS \"TSB\" FROM athlete_stats ORDER BY date DESC LIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": -40,
          "max": 40,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": -10
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "super-light-green",
                "value": 15
              },
              {
                "color": "blue",
                "value": 25
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Recent Activities",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT \n  name,\n  date::date AS date,\n  CASE WHEN distance_m > 0 THEN ROUND((distance_m / 1000.0)::numeric, 1)::text ELSE 'N/A' END AS \"km\",\n  ROUND((duration_s / 60.0)::numeric, 0) AS \"min\",\n  COALESCE(avg_hr::text, 'N/A') AS \"avg_hr\",\n  CASE WHEN elevation_m > 0 THEN ROUND(elevation_m::numeric, 0)::text ELSE 'N/A' END AS \"elev_m\",\n  CASE WHEN is_indoor THEN 'Indoor' ELSE 'Outdoor' END AS \"type\",\n  device\nFROM activities\nWHERE $__timeFilter(date)\nORDER BY date DESC\nLIMIT 10;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}