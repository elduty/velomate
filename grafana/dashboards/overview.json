            "barWidthFactor": 0.8
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 9,
      "title": "Activities",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  name AS \"Name\",\n  date::date AS \"Date\",\n  CASE WHEN distance_m > 0 THEN ROUND((distance_m / 1000.0)::numeric, 1)::text ELSE 'N/A' END AS \"Distance (km)\",\n  ROUND((duration_s / 60.0)::numeric, 0) AS \"Duration (min)\",\n  COALESCE(avg_hr::text, 'N/A') AS \"Avg HR (bpm)\",\n  CASE WHEN elevation_m > 0 THEN ROUND(elevation_m::numeric, 0)::text ELSE 'N/A' END AS \"Elevation (m)\",\n  COALESCE(calories::text, 'N/A') AS \"Calories (kcal)\",\n  CASE WHEN is_indoor THEN 'Indoor' ELSE 'Outdoor' END AS \"Type\",\n  device AS \"Device\"\nFROM activities\nWHERE $__timeFilter(date)\nORDER BY date DESC\nLIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 10,
      "title": "Avg Heart Rate (bpm)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, ROUND(AVG(avg_hr)::numeric, 1) AS \"Outdoor bpm\" FROM activities WHERE $__timeFilter(date) AND avg_hr IS NOT NULL AND is_indoor = false GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
          "rawSql": "SELECT date_trunc('day', date) AS time, ROUND(AVG(avg_hr)::numeric, 1) AS \"Indoor bpm\" FROM activities WHERE $__timeFilter(date) AND avg_hr IS NOT NULL AND is_indoor = true GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bpm",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ],
  "schemaVersion": 39,
