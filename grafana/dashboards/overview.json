{
  "uid": "veloai-main",
  "title": "Overview",
  "tags": ["veloai"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "graphTooltip": 2,
  "time": { "from": "now-7d", "to": "now" },
  "refresh": "5m",
  "links": [
    {
      "title": "Fitness Trends",
      "url": "/d/veloai-fitness/fitness-trends",
      "type": "link",
      "icon": "dashboard",
      "keepTime": true
    },
    {
      "title": "Activity Detail",
      "url": "/d/veloai-activity/activity-detail",
      "type": "link",
      "icon": "dashboard"
    },
    {
      "title": "Weekly Report",
      "url": "/d/veloai-weekly/weekly-report",
      "type": "link",
      "icon": "dashboard",
      "keepTime": true
    },
    {
      "title": "Training Log",
      "url": "/d/veloai-training-log/training-log",
      "type": "link",
      "icon": "dashboard",
      "keepTime": true
    },
    {
      "title": "Year in Review",
      "url": "/d/veloai-year-review/year-in-review",
      "type": "link",
      "icon": "dashboard"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "group_by",
        "type": "custom",
        "label": "Group by",
        "query": "day,week,month",
        "current": {
          "text": "day",
          "value": "day"
        },
        "options": [
          {
            "text": "day",
            "value": "day",
            "selected": true
          },
          {
            "text": "week",
            "value": "week",
            "selected": false
          },
          {
            "text": "month",
            "value": "month",
            "selected": false
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Rides",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT COUNT(*) AS \"Rides\" FROM activities WHERE $__timeFilter(date);", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" }
        }
      }
    },
    {
      "id": 2,
      "title": "Distance",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 2, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT ROUND((COALESCE(SUM(distance_m), 0) / 1000.0)::numeric, 1) AS \"Distance\" FROM activities WHERE $__timeFilter(date);", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "color": { "fixedColor": "#33658a", "mode": "fixed" }
        }
      }
    },
    {
      "id": 3,
      "title": "Elevation",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 5, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT ROUND(COALESCE(SUM(elevation_m), 0)::numeric, 0) AS \"Elevation\" FROM activities WHERE $__timeFilter(date);", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "color": { "fixedColor": "#ff9830", "mode": "fixed" }
        }
      }
    },
    {
      "id": 4,
      "title": "Duration",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT COALESCE(SUM(duration_s), 0) AS \"Duration\" FROM activities WHERE $__timeFilter(date);", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" }
        }
      }
    },
    {
      "id": 5,
      "title": "Calories",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 11, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT COALESCE(SUM(calories), 0) AS \"Calories\" FROM activities WHERE $__timeFilter(date) AND calories IS NOT NULL;", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "color": { "fixedColor": "#F2495C", "mode": "fixed" }
        }
      }
    },
    {
      "id": 6,
      "title": "TSS",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 14, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT ROUND(COALESCE(SUM(tss), 0)::numeric, 0) AS \"TSS\" FROM activities WHERE $__timeFilter(date);", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#8b5cf6", "mode": "fixed" }
        }
      }
    },
    {
      "id": 7,
      "title": "Avg Power",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 17, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT ROUND(AVG(avg_power)::numeric, 0) AS \"Power\" FROM activities WHERE $__timeFilter(date) AND avg_power > 0;", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "fixedColor": "#8b5cf6", "mode": "fixed" }
        }
      }
    },
    {
      "id": 8,
      "title": "Avg Speed",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 19, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT ROUND(AVG(avg_speed_kmh)::numeric, 1) AS \"Speed\" FROM activities WHERE $__timeFilter(date) AND avg_speed_kmh > 0 AND distance_m > 5000;", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "color": { "fixedColor": "#73bf69", "mode": "fixed" }
        }
      }
    },
    {
      "id": 9,
      "title": "Avg HR",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 22, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT ROUND(AVG(avg_hr)::numeric, 0) AS \"HR\" FROM activities WHERE $__timeFilter(date) AND avg_hr > 0;", "format": "table", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#F2495C", "mode": "fixed" }
        }
      }
    },
    {
      "id": 11,
      "title": "Distance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.distance_m) / 1000.0, 0) AS \"Outdoor (km)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.sport_type = 'cycling_outdoor' GROUP BY gs ORDER BY gs;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.distance_m) / 1000.0, 0) AS \"Zwift (km)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.sport_type = 'zwift' GROUP BY gs ORDER BY gs;",
          "format": "time_series",
          "refId": "B"
        },
        {
          "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.distance_m) / 1000.0, 0) AS \"E-Bike (km)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.sport_type = 'ebike' GROUP BY gs ORDER BY gs;",
          "format": "time_series",
          "refId": "C"
        },
        {
          "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.distance_m) / 1000.0, 0) AS \"Indoor (km)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.sport_type = 'cycling_indoor' GROUP BY gs ORDER BY gs;",
          "format": "time_series",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" },
            "barWidthFactor": 0.6
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Outdoor (km)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33658a", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Zwift (km)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#fc4c02", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "E-Bike (km)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73bf69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Indoor (km)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#8b5cf6", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 12,
      "title": "Elevation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.elevation_m), 0) AS \"Outdoor (m)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.sport_type = 'cycling_outdoor' GROUP BY gs ORDER BY gs;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.elevation_m), 0) AS \"Zwift (m)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.sport_type = 'zwift' GROUP BY gs ORDER BY gs;",
          "format": "time_series",
          "refId": "B"
        },
        {
          "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.elevation_m), 0) AS \"E-Bike (m)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.sport_type = 'ebike' GROUP BY gs ORDER BY gs;",
          "format": "time_series",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" },
            "barWidthFactor": 0.6
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Outdoor (m)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#33658a", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Zwift (m)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#fc4c02", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "E-Bike (m)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73bf69", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 13,
      "title": "Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT gs AS \"time\", COALESCE(SUM(a.duration_s) / 3600.0, 0) AS \"Hours\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs GROUP BY gs ORDER BY gs;", "format": "time_series", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
