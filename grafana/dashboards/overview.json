      "title": "Avg Speed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT gs AS \"time\", COALESCE(ROUND(AVG(a.avg_speed_kmh)::numeric, 1), 0) AS \"Avg Speed (km/h)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.avg_speed_kmh > 0 AND a.distance_m > 5000 GROUP BY gs ORDER BY gs;", "format": "time_series", "refId": "A" }],
