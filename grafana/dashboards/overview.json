              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "green",
                "value": 1000
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
