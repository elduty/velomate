    {
      "id": 200,
      "type": "row",
      "title": "Fitness",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "panels": [
        {
          "id": 201,
          "title": "CTL / ATL / TSB",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
          "datasource": { "type": "postgres", "uid": "veloai" },
          "targets": [
            {
              "rawSql": "SELECT date AS \"time\", ctl AS \"Fitness (CTL)\", atl AS \"Fatigue (ATL)\", tsb AS \"Form (TSB)\" FROM athlete_stats WHERE $__timeFilter(date) ORDER BY date;",
              "format": "time_series",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineWidth": 2,
                "fillOpacity": 0
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Fitness (CTL)"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "fixedColor": "#6ed0ff",
                      "mode": "fixed"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "Fatigue (ATL)"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "fixedColor": "#ff9830",
                      "mode": "fixed"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "Form (TSB)"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "fixedColor": "#73bf69",
                      "mode": "fixed"
                    }
                  },
                  {
                    "id": "custom.lineStyle",
                    "value": {
                      "fill": "dash",
                      "dash": [6, 4]
                    }
                  },
                  {
                    "id": "custom.fillOpacity",
                    "value": 10
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Outdoor Records & Progress",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "panels": [
        {
          "id": 202,
          "title": "Longest Ride (Period)",
          "type": "stat",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 0,
            "y": 37
          },
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          },
