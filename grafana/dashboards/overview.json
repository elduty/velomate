    {
      "id": 15,
      "title": "Avg Power",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{ "rawSql": "SELECT gs AS \"time\", COALESCE(ROUND(AVG(a.avg_power)::numeric, 0), 0) AS \"Avg Power (W)\" FROM generate_series(date_trunc('${group_by}', $__timeFrom()::timestamptz), date_trunc('${group_by}', $__timeTo()::timestamptz), '1 ${group_by}'::interval) gs LEFT JOIN activities a ON date_trunc('${group_by}', a.date) = gs AND a.avg_power > 0 GROUP BY gs ORDER BY gs;", "format": "time_series", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#8b5cf6", "mode": "fixed" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barWidthFactor": 0.6
          }
        }
      }
    },
    {
