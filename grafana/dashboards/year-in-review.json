{
  "uid": "veloai-year-review",
  "title": "Year in Review",
  "tags": ["veloai"],
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now/y",
    "to": "now"
  },
  "refresh": "",
  "links": [
    {
      "title": "Overview",
      "url": "/d/veloai-main/overview",
      "type": "link",
      "icon": "dashboard"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "year",
        "type": "custom",
        "label": "Year",
        "query": "2026,2025,2024,2023,2022,2021,2020",
        "current": {
          "text": "2026",
          "value": "2026"
        },
        "options": [
          { "text": "2026", "value": "2026", "selected": true },
          { "text": "2025", "value": "2025", "selected": false },
          { "text": "2024", "value": "2024", "selected": false },
          { "text": "2023", "value": "2023", "selected": false },
          { "text": "2022", "value": "2022", "selected": false },
          { "text": "2021", "value": "2021", "selected": false },
          { "text": "2020", "value": "2020", "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Distance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT ROUND(COALESCE(SUM(distance_m), 0) / 1000.0::numeric, 0) AS \"Distance\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year};",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "color": { "fixedColor": "#33658a", "mode": "fixed" }
        }
      }
    },
    {
      "id": 2,
      "title": "Elevation",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT ROUND(COALESCE(SUM(elevation_m), 0)::numeric, 0) AS \"Elevation\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year};",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "color": { "fixedColor": "#ff9830", "mode": "fixed" }
        }
      }
    },
    {
      "id": 3,
      "title": "Rides",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Rides\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year};",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" }
        }
      }
    },
    {
      "id": 4,
      "title": "Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT COALESCE(SUM(duration_s), 0) AS \"Duration\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year};",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" }
        }
      }
    },
    {
      "id": 5,
      "title": "Calories",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT COALESCE(SUM(calories), 0) AS \"Calories\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} AND calories IS NOT NULL;",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "color": { "fixedColor": "#F2495C", "mode": "fixed" }
        }
      }
    },
    {
      "id": 6,
      "title": "TSS",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT ROUND(COALESCE(SUM(tss), 0)::numeric, 0) AS \"TSS\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year};",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#8b5cf6", "mode": "fixed" }
        }
      }
    },
    {
      "id": 7,
      "title": "vs Previous Year (same period)",
      "type": "table",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "WITH curr AS (SELECT COALESCE(SUM(distance_m)/1000.0, 0) AS dist, COALESCE(SUM(elevation_m), 0) AS elev, COUNT(*) AS rides, COALESCE(SUM(duration_s)/3600.0, 0) AS hours FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} AND EXTRACT(DOY FROM date) <= EXTRACT(DOY FROM now())), prev AS (SELECT COALESCE(SUM(distance_m)/1000.0, 0) AS dist, COALESCE(SUM(elevation_m), 0) AS elev, COUNT(*) AS rides, COALESCE(SUM(duration_s)/3600.0, 0) AS hours FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} - 1 AND EXTRACT(DOY FROM date) <= EXTRACT(DOY FROM now())) SELECT ROUND((curr.dist - prev.dist)::numeric, 0) AS \"Distance (km)\", CASE WHEN prev.dist > 0 THEN ROUND(((curr.dist - prev.dist) / prev.dist * 100)::numeric, 0) ELSE NULL END AS \"Dist %\", ROUND((curr.elev - prev.elev)::numeric, 0) AS \"Elevation (m)\", ROUND((curr.rides - prev.rides)::numeric, 0) AS \"Rides\", ROUND((curr.hours - prev.hours)::numeric, 1) AS \"Hours\" FROM curr, prev;",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Dist %" },
            "properties": [{ "id": "unit", "value": "percent" }]
          }
        ]
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Monthly Volume",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "panels": []
    },
    {
      "id": 10,
      "title": "Monthly Distance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', date) AS time, SUM(CASE WHEN sport_type = 'cycling_outdoor' THEN distance_m ELSE 0 END) / 1000.0 AS \"Outdoor (km)\", SUM(CASE WHEN sport_type = 'zwift' THEN distance_m ELSE 0 END) / 1000.0 AS \"Zwift (km)\", SUM(CASE WHEN sport_type = 'ebike' THEN distance_m ELSE 0 END) / 1000.0 AS \"E-Bike (km)\", SUM(CASE WHEN sport_type = 'cycling_indoor' THEN distance_m ELSE 0 END) / 1000.0 AS \"Indoor (km)\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date_trunc('month', date) + interval '1 year' AS time, SUM(distance_m) / 1000.0 AS \"Previous Year\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} - 1 GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" },
            "barWidthFactor": 0.6
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Outdoor (km)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#33658a", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Zwift (km)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#fc4c02", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "E-Bike (km)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73bf69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Indoor (km)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#8b5cf6", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Previous Year" }, "properties": [
            { "id": "color", "value": { "fixedColor": "#555555", "mode": "fixed" } },
            { "id": "custom.drawStyle", "value": "line" },
            { "id": "custom.fillOpacity", "value": 0 },
            { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } },
            { "id": "custom.stacking", "value": { "mode": "none" } }
          ]}
        ]
      }
    },
    {
      "id": 11,
      "title": "Monthly Elevation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', date) AS time, SUM(CASE WHEN sport_type = 'cycling_outdoor' THEN elevation_m ELSE 0 END) AS \"Outdoor (m)\", SUM(CASE WHEN sport_type = 'zwift' THEN elevation_m ELSE 0 END) AS \"Zwift (m)\", SUM(CASE WHEN sport_type = 'ebike' THEN elevation_m ELSE 0 END) AS \"E-Bike (m)\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date_trunc('month', date) + interval '1 year' AS time, SUM(elevation_m) AS \"Previous Year\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} - 1 GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" },
            "barWidthFactor": 0.6
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Outdoor (m)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#33658a", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Zwift (m)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#fc4c02", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "E-Bike (m)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73bf69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Previous Year" }, "properties": [
            { "id": "color", "value": { "fixedColor": "#555555", "mode": "fixed" } },
            { "id": "custom.drawStyle", "value": "line" },
            { "id": "custom.fillOpacity", "value": 0 },
            { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } },
            { "id": "custom.stacking", "value": { "mode": "none" } }
          ]}
        ]
      }
    },
    {
      "id": 12,
      "title": "Monthly Rides",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', date) AS time, COUNT(*) AS \"Rides\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date_trunc('month', date) + interval '1 year' AS time, COUNT(*) AS \"Previous Year\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} - 1 GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "barWidthFactor": 0.6 },
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Previous Year" }, "properties": [
            { "id": "color", "value": { "fixedColor": "#555555", "mode": "fixed" } },
            { "id": "custom.drawStyle", "value": "line" },
            { "id": "custom.fillOpacity", "value": 0 },
            { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } }
          ]}
        ]
      }
    },
    {
      "id": 13,
      "title": "Monthly Hours",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', date) AS time, ROUND((SUM(duration_s) / 3600.0)::numeric, 1) AS \"Hours\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date_trunc('month', date) + interval '1 year' AS time, ROUND((SUM(duration_s) / 3600.0)::numeric, 1) AS \"Previous Year\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} - 1 GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "barWidthFactor": 0.6 },
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Previous Year" }, "properties": [
            { "id": "color", "value": { "fixedColor": "#555555", "mode": "fixed" } },
            { "id": "custom.drawStyle", "value": "line" },
            { "id": "custom.fillOpacity", "value": 0 },
            { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } }
          ]}
        ]
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Trends",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "panels": []
    },
    {
      "id": 20,
      "title": "Avg Distance per Ride",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT date_trunc('month', date) AS time, ROUND((AVG(distance_m) / 1000.0)::numeric, 1) AS \"Avg Distance (km)\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} AND is_indoor IS NOT TRUE GROUP BY 1 ORDER BY 1;",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "color": { "fixedColor": "#33658a", "mode": "fixed" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "pointSize": 6, "spanNulls": true }
        }
      }
    },
    {
      "id": 21,
      "title": "Avg Speed per Ride",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT date_trunc('month', date) AS time, ROUND(AVG(avg_speed_kmh)::numeric, 1) AS \"Avg Speed (km/h)\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} AND is_indoor IS NOT TRUE AND avg_speed_kmh > 0 AND distance_m > 5000 GROUP BY 1 ORDER BY 1;",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "color": { "fixedColor": "#73bf69", "mode": "fixed" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "pointSize": 6, "spanNulls": true }
        }
      }
    },
    {
      "id": 22,
      "title": "Monthly TSS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT date_trunc('month', date) AS time, ROUND(SUM(tss)::numeric, 0) AS \"TSS\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} AND tss IS NOT NULL GROUP BY 1 ORDER BY 1;",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#8b5cf6", "mode": "fixed" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "barWidthFactor": 0.6 }
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Fitness Progression",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "panels": []
    },
    {
      "id": 30,
      "title": "CTL (Fitness) by Month",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT date AS time, ctl AS \"Fitness (CTL)\" FROM athlete_stats WHERE EXTRACT(YEAR FROM date) = ${year} ORDER BY date;",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }
        }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Consistency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "panels": []
    },
    {
      "id": 40,
      "title": "Rides by Day of Week",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 43 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT CASE EXTRACT(DOW FROM date) WHEN 0 THEN 'Sun' WHEN 1 THEN 'Mon' WHEN 2 THEN 'Tue' WHEN 3 THEN 'Wed' WHEN 4 THEN 'Thu' WHEN 5 THEN 'Fri' WHEN 6 THEN 'Sat' END AS \"Day\", COUNT(*) AS \"Rides\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} GROUP BY EXTRACT(DOW FROM date) ORDER BY EXTRACT(DOW FROM date);",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#6ed0ff", "mode": "fixed" }
        }
      }
    },
    {
      "id": 41,
      "title": "Rides by Start Hour",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 43 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT LPAD(EXTRACT(HOUR FROM date)::text, 2, '0') || ':00' AS \"Hour\", COUNT(*) AS \"Rides\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} GROUP BY EXTRACT(HOUR FROM date) ORDER BY EXTRACT(HOUR FROM date);",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#ff9830", "mode": "fixed" }
        }
      }
    },
    {
      "id": 42,
      "title": "Longest Streak per Month",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 43 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "WITH ride_days AS (SELECT DISTINCT date::date AS d FROM activities WHERE EXTRACT(YEAR FROM date) = ${year}), streaks AS (SELECT d, d - (ROW_NUMBER() OVER (ORDER BY d))::int AS grp FROM ride_days), streak_lengths AS (SELECT MIN(d) AS streak_start, COUNT(*) AS len FROM streaks GROUP BY grp) SELECT TO_CHAR(streak_start, 'Mon') AS \"Month\", MAX(len) AS \"Longest Streak (days)\" FROM streak_lengths GROUP BY EXTRACT(MONTH FROM streak_start), TO_CHAR(streak_start, 'Mon') ORDER BY EXTRACT(MONTH FROM streak_start);",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#73bf69", "mode": "fixed" }
        }
      }
    },
    {
      "id": 104,
      "type": "row",
      "title": "Monthly Bests",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "panels": []
    },
    {
      "id": 50,
      "title": "Best Ride Each Month",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 52 },
      "datasource": { "type": "postgres", "uid": "veloai" },
      "targets": [{
        "rawSql": "SELECT DISTINCT ON (EXTRACT(MONTH FROM date)) TO_CHAR(date, 'Mon') AS \"Month\", name AS \"Name\", TO_CHAR(date, 'YYYY-MM-DD') AS \"Date\", ROUND((distance_m / 1000.0)::numeric, 1) AS \"Distance (km)\", ROUND(elevation_m::numeric, 0) AS \"Elevation (m)\", TO_CHAR(duration_s * interval '1 second', 'HH24:MI') AS \"Duration\", ROUND(avg_speed_kmh::numeric, 1) AS \"Avg Speed\", COALESCE(avg_power::text, '—') AS \"Avg Power\", ROUND(tss::numeric, 0) AS \"TSS\" FROM activities WHERE EXTRACT(YEAR FROM date) = ${year} AND is_indoor IS NOT TRUE AND distance_m > 0 ORDER BY EXTRACT(MONTH FROM date), distance_m DESC;",
        "format": "table",
        "refId": "A"
      }],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 105,
      "type": "row",
      "title": "Year-over-Year",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 },
      "panels": []
    },
    {
      "id": 60,
      "title": "Year-over-Year Comparison",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 61 },
