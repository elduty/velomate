{
  "uid": "veloai-training-log",
  "title": "Training Log",
  "tags": [
    "veloai"
  ],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "",
  "links": [
    {
      "title": "Overview",
      "url": "/d/veloai-main/veloai-overview",
      "type": "link",
      "icon": "dashboard",
      "keepTime": true
    },
    {
      "title": "Weekly Report",
      "url": "/d/veloai-weekly/weekly-report",
      "type": "link",
      "icon": "dashboard",
      "keepTime": true
    },
    {
      "title": "Activity Detail",
      "url": "/d/veloai-activity/activity-detail",
      "type": "link",
      "icon": "dashboard"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Total Rides",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Rides\" FROM activities WHERE $__timeFilter(date);",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Distance",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 5,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND((SUM(distance_m)/1000.0)::numeric, 0) AS \"Distance\" FROM activities WHERE $__timeFilter(date);",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Elevation",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 10,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM(elevation_m)::numeric, 0) AS \"Elevation\" FROM activities WHERE $__timeFilter(date);",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total TSS",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 15,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM(tss)::numeric, 0) AS \"TSS\" FROM activities WHERE $__timeFilter(date);",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Avg TSS/Ride",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND((SUM(tss) / GREATEST(COUNT(*), 1))::numeric, 0) AS \"Avg TSS\" FROM activities WHERE $__timeFilter(date);",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Training Log",
      "type": "table",
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT a.id, a.name AS \"Name\", TO_CHAR(a.date, 'YYYY-MM-DD') AS \"Date\", TO_CHAR(a.date, 'Dy') AS \"Day\", ROUND((a.distance_m / 1000.0)::numeric, 1) AS \"Dist (km)\", ROUND(a.elevation_m::numeric, 0) AS \"Elev (m)\", TO_CHAR(a.duration_s * interval '1 second', 'HH24:MI') AS \"Time\", ROUND(a.avg_speed_kmh::numeric, 1) AS \"Avg Speed\", COALESCE(a.avg_hr::text, '—') AS \"Avg HR\", COALESCE(a.avg_power::text, '—') AS \"Avg W\", COALESCE(ROUND(a.tss::numeric, 0)::text, '—') AS \"TSS\", CASE a.sport_type WHEN 'cycling_outdoor' THEN 'Outdoor' WHEN 'cycling_indoor' THEN 'Indoor' WHEN 'zwift' THEN 'Zwift' WHEN 'strength' THEN 'Strength' ELSE COALESCE(a.sport_type, '—') END AS \"Type\", EXTRACT(EPOCH FROM a.date - interval '1 hour')::bigint * 1000 AS from_ts, EXTRACT(EPOCH FROM a.date + a.duration_s * interval '1 second' + interval '1 hour')::bigint * 1000 AS to_ts FROM activities a WHERE $__timeFilter(a.date) AND ('${sport_type}' = 'All' OR a.sport_type = '${sport_type}') ORDER BY a.date DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "id"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "from_ts"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "to_ts"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Name"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Activity",
                    "url": "/d/veloai-activity/activity-detail?var-activity_id=${__data.fields.id}&from=${__data.fields.from_ts}&to=${__data.fields.to_ts}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "TSS"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 50
                    },
                    {
                      "color": "red",
                      "value": 100
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Cumulative Distance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT date AS \"time\", SUM(distance_m / 1000.0) OVER (ORDER BY date) AS \"Cumulative (km)\" FROM (SELECT date_trunc('day', date) AS date, SUM(distance_m) AS distance_m FROM activities WHERE $__timeFilter(date) GROUP BY 1) d ORDER BY date;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#33658a",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Cumulative TSS",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT date AS \"time\", SUM(tss) OVER (ORDER BY date) AS \"Cumulative TSS\" FROM (SELECT date_trunc('day', date) AS date, SUM(tss) AS tss FROM activities WHERE $__timeFilter(date) GROUP BY 1) d ORDER BY date;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#8b5cf6",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "sport_type",
        "type": "custom",
        "label": "Sport",
        "query": "All,cycling_outdoor,cycling_indoor,zwift",
        "current": {
          "text": "All",
          "value": "All"
        },
        "options": [
          {
            "text": "All",
            "value": "All",
            "selected": true
          },
          {
            "text": "Outdoor",
            "value": "cycling_outdoor",
            "selected": false
          },
          {
            "text": "Indoor",
            "value": "cycling_indoor",
            "selected": false
          },
          {
            "text": "Zwift",
            "value": "zwift",
            "selected": false
          }
        ]
      }
    ]
  }
}