    {
      "id": 20,
      "title": "Speed & Elevation",
      "type": "trend",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "WITH deltas AS (\n  SELECT\n    time_offset, speed_kmh,\n    altitude_m,\n    COALESCE(speed_kmh, 0) / 3600.0 *\n      (time_offset - LAG(time_offset, 1, time_offset) OVER (ORDER BY time_offset)) AS dist_delta\n  FROM activity_streams\n  WHERE activity_id = ${activity_id}\n)\nSELECT\n  ROUND(SUM(dist_delta) OVER (ORDER BY time_offset ROWS UNBOUNDED PRECEDING)::numeric, 2) AS \"Distance (km)\",\n  speed_kmh AS \"Speed (km/h)\",\n  altitude_m AS \"Elevation (m)\"\nFROM deltas\nORDER BY 1;",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          }
        }
      ],
      "options": {
        "xField": "Distance (km)",
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "pointSize": 3,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Speed (km/h)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "velocitykmh"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5794F2"
                }
              },
              {
                "id": "custom.axisPlacement",
                "value": "left"
              },
              {
                "id": "custom.axisLabel",
                "value": "Speed (km/h)"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Elevation (m)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "lengthm"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#73BF69"
                }
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": "Elevation (m)"
              },
              {
                "id": "custom.fillOpacity",
                "value": 30
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "custom.fillBelowTo",
                "value": "Elevation (m)"
              },
              {
                "id": "custom.lineInterpolation",
                "value": "smooth"
              }
            ]
          }
        ]
      }
    },
