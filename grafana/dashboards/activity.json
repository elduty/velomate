          "text": "Speed",
          "value": "speed_kmh"
        },
        "options": [
          {
            "text": "Speed",
            "value": "speed_kmh",
            "selected": true
          },
          {
            "text": "Heart Rate",
            "value": "hr",
            "selected": false
          },
          {
            "text": "Power",
            "value": "power",
            "selected": false
          }
        ]
      }
    ]
