{
  "uid": "veloai-activity",
  "title": "Activity Details",
  "tags": [
    "veloai"
  ],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 3,
  "graphTooltip": 2,
  "time": {
    "from": "now-2y",
    "to": "now"
  },
  "refresh": "",
  "links": [
    {
      "title": "Overview",
      "url": "/d/veloai-main/overview",
      "type": "link",
      "icon": "dashboard",
      "keepTime": true
    }
  ],
  "templating": {
    "list": [
      {
        "name": "activity_id",
        "type": "query",
        "label": "Activity",
        "datasource": {
          "type": "postgres",
          "uid": "veloai"
        },
        "query": "SELECT id AS __value, name || ' (' || TO_CHAR(date, 'YYYY-MM-DD') || ')' AS __text FROM activities ORDER BY date DESC",
        "refresh": 2,
        "sort": 0,
        "current": {},
        "options": []
      },
      {
        "name": "map_metric",
        "type": "custom",
        "label": "Map color",
        "query": "speed_kmh,hr,power",
        "current": {
          "text": "Speed",
          "value": "speed_kmh"
        },
        "options": [
          {
            "text": "Speed",
            "value": "speed_kmh",
            "selected": true
          },
          {
            "text": "Heart Rate",
            "value": "hr",
            "selected": false
          },
          {
            "text": "Power",
            "value": "power",
            "selected": false
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 30,
      "title": "Route",
      "type": "geomap",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "SELECT lat AS \"latitude\", lng AS \"longitude\", CASE '${map_metric}' WHEN 'speed_kmh' THEN speed_kmh WHEN 'hr' THEN hr WHEN 'power' THEN power END AS \"metric\", time_offset FROM activity_streams WHERE activity_id = ${activity_id} AND lat IS NOT NULL AND lng IS NOT NULL ORDER BY time_offset;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "view": {
          "id": "fit",
          "lat": 0,
          "lon": 0,
          "zoom": 12
        },
        "layers": [
          {
            "type": "route",
            "name": "Route",
            "config": {
              "style": {
                "color": {
                  "field": "metric",
                  "fixed": "green"
                },
                "opacity": 0.8,
                "lineWidth": 3
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "latitude",
              "longitude": "longitude"
            }
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "metric"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 31,
      "title": "HR Zones",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "WITH lthr AS (SELECT percentile_cont(0.95) WITHIN GROUP (ORDER BY max_hr) AS thr FROM activities WHERE max_hr IS NOT NULL AND max_hr > 0), counts AS (SELECT CASE WHEN s.hr < lthr.thr * 0.68 THEN 'Z1 Recovery' WHEN s.hr < lthr.thr * 0.83 THEN 'Z2 Endurance' WHEN s.hr < lthr.thr * 0.94 THEN 'Z3 Tempo' WHEN s.hr < lthr.thr * 1.05 THEN 'Z4 Threshold' ELSE 'Z5 VO2max' END AS zone_name, COUNT(*) AS secs FROM activity_streams s, lthr WHERE s.activity_id = ${activity_id} AND s.hr IS NOT NULL AND s.hr > 0 GROUP BY zone_name) SELECT COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z1 Recovery'), 0) AS \"Z1 Recovery\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z2 Endurance'), 0) AS \"Z2 Endurance\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z3 Tempo'), 0) AS \"Z3 Tempo\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z4 Threshold'), 0) AS \"Z4 Threshold\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z5 VO2max'), 0) AS \"Z5 VO2max\";",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "min"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Z1 Recovery"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#808080",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z2 Endurance"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#3498db",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z3 Tempo"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#2ecc71",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z4 Threshold"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f1c40f",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z5 VO2max"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#e74c3c",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 32,
      "title": "Power Zones",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "WITH ftp AS (SELECT percentile_cont(0.95) WITHIN GROUP (ORDER BY avg_power) AS ftp_val FROM activities WHERE avg_power IS NOT NULL AND avg_power > 0), counts AS (SELECT CASE WHEN s.power < ftp.ftp_val * 0.55 THEN 'Z1 Recovery' WHEN s.power < ftp.ftp_val * 0.75 THEN 'Z2 Endurance' WHEN s.power < ftp.ftp_val * 0.90 THEN 'Z3 Tempo' WHEN s.power < ftp.ftp_val * 1.05 THEN 'Z4 Threshold' WHEN s.power < ftp.ftp_val * 1.20 THEN 'Z5 VO2max' ELSE 'Z6 Anaerobic' END AS zone_name, COUNT(*) AS secs FROM activity_streams s, ftp WHERE s.activity_id = ${activity_id} AND s.power IS NOT NULL AND s.power > 0 GROUP BY zone_name) SELECT COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z1 Recovery'), 0) AS \"Z1 Recovery\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z2 Endurance'), 0) AS \"Z2 Endurance\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z3 Tempo'), 0) AS \"Z3 Tempo\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z4 Threshold'), 0) AS \"Z4 Threshold\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z5 VO2max'), 0) AS \"Z5 VO2max\", COALESCE((SELECT ROUND(secs/60.0::numeric, 1) FROM counts WHERE zone_name = 'Z6 Anaerobic'), 0) AS \"Z6 Anaerobic\";",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "min"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Z1 Recovery"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#808080",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z2 Endurance"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#3498db",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z3 Tempo"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#2ecc71",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z4 Threshold"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f1c40f",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z5 VO2max"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#e67e22",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Z6 Anaerobic"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#e74c3c",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 33,
      "title": "Per-km Splits",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "WITH deltas AS (SELECT time_offset, hr, power, speed_kmh, altitude_m, COALESCE(speed_kmh, 0) / 3600.0 * (time_offset - LAG(time_offset, 1, time_offset) OVER (ORDER BY time_offset)) AS dist_delta FROM activity_streams WHERE activity_id = ${activity_id}), cumulative AS (SELECT time_offset, hr, power, speed_kmh, altitude_m, SUM(dist_delta) OVER (ORDER BY time_offset ROWS UNBOUNDED PRECEDING) AS dist_km FROM deltas), splits AS (SELECT FLOOR(dist_km)::int + 1 AS \"KM\", ROUND(AVG(speed_kmh)::numeric, 1) AS \"Avg Speed\", ROUND(AVG(hr)::numeric, 0) AS \"Avg HR\", ROUND(AVG(NULLIF(power, 0))::numeric, 0) AS \"Avg Power\", ROUND((MAX(altitude_m) - MIN(altitude_m))::numeric, 0) AS \"Elev Range (m)\", COUNT(*) AS seconds FROM cumulative WHERE dist_km >= 0 GROUP BY FLOOR(dist_km)::int) SELECT \"KM\", \"Avg Speed\", \"Avg HR\", COALESCE(\"Avg Power\"::text, '\u2014') AS \"Avg Power\", \"Elev Range (m)\", TO_CHAR(seconds * interval '1 second', 'MI:SS') AS \"Time\" FROM splits ORDER BY \"KM\";",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 20,
      "title": "Speed & Elevation",
      "type": "trend",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "WITH deltas AS (\n  SELECT\n    time_offset, speed_kmh,\n    altitude_m,\n    COALESCE(speed_kmh, 0) / 3600.0 *\n      (time_offset - LAG(time_offset, 1, time_offset) OVER (ORDER BY time_offset)) AS dist_delta\n  FROM activity_streams\n  WHERE activity_id = ${activity_id}\n)\nSELECT\n  ROUND(SUM(dist_delta) OVER (ORDER BY time_offset ROWS UNBOUNDED PRECEDING)::numeric, 2) AS \"Distance (km)\",\n  speed_kmh AS \"Speed (km/h)\",\n  altitude_m AS \"Elevation (m)\"\nFROM deltas\nORDER BY 1;",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "veloai"
          }
        }
      ],
      "options": {
        "xField": "Distance (km)",
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
