        "x": 12,
        "y": 67
      },
      "datasource": {
        "type": "postgres",
        "uid": "veloai"
      },
      "targets": [
        {
          "rawSql": "WITH rolling AS (SELECT AVG(power) OVER (ORDER BY time_offset RANGE BETWEEN 29 PRECEDING AND CURRENT ROW) AS rolling_30s FROM activity_streams WHERE activity_id = ${activity_id} AND power IS NOT NULL AND power > 0), np AS (SELECT POWER(AVG(POWER(rolling_30s, 4)), 0.25) AS np_val FROM rolling WHERE rolling_30s IS NOT NULL) SELECT ROUND((np.np_val / a.avg_power)::numeric, 2) AS \"VI\" FROM np, activities a WHERE a.id = ${activity_id} AND a.avg_power > 0;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1.05
              },
              {
                "color": "red",
                "value": 1.15
              }
            ]
          }
        },
