{
  "uid": "veloai-activity",
  "title": "Activity Detail",
  "tags": ["veloai"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 2,
  "time": {"from": "now-2y", "to": "now"},
  "refresh": "",
  "templating": {
    "list": [
      {
        "name": "activity_id",
        "type": "textbox",
        "label": "Activity ID",
        "hide": 2,
        "current": {"value": "0"},
        "options": [],
        "query": "0"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Activity",
      "type": "stat",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "postgres", "uid": "veloai"},
      "targets": [
        {
          "rawSql": "SELECT name AS \"Name\", CASE WHEN is_indoor THEN 'Indoor' ELSE 'Outdoor' END AS \"Type\", ROUND((distance_m/1000.0)::numeric,1) AS \"Distance (km)\", duration_s AS \"Duration\", ROUND(elevation_m::numeric,0) AS \"Elevation (m)\", ROUND(avg_speed_kmh::numeric,1) AS \"Avg Speed\", avg_hr AS \"Avg HR\", avg_power AS \"Avg Power\", calories AS \"Calories\" FROM activities WHERE id = ${activity_id};",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/.*/"},
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "text", "value": null}]}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Duration"},
            "properties": [{"id": "unit", "value": "s"}]
          },
          {
            "matcher": {"id": "byName", "options": "Distance (km)"},
            "properties": [{"id": "unit", "value": "lengthkm"}]
          },
          {
            "matcher": {"id": "byName", "options": "Elevation (m)"},
            "properties": [{"id": "unit", "value": "lengthm"}]
          },
          {
            "matcher": {"id": "byName", "options": "Avg Speed"},
            "properties": [{"id": "unit", "value": "velocitykmh"}]
          },
          {
            "matcher": {"id": "byName", "options": "Avg HR"},
            "properties": [{"id": "unit", "value": "bpm"}]
          },
          {
            "matcher": {"id": "byName", "options": "Avg Power"},
            "properties": [{"id": "unit", "value": "watt"}]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Speed & Elevation",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "postgres", "uid": "veloai"},
      "targets": [
        {
          "rawSql": "SELECT a.date + (s.time_offset * interval '1 second') AS time, ROUND(s.speed_kmh::numeric,1) AS \"Speed (km/h)\" FROM activity_streams s JOIN activities a ON a.id = s.activity_id WHERE s.activity_id = ${activity_id} AND s.speed_kmh IS NOT NULL ORDER BY time;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT a.date + (s.time_offset * interval '1 second') AS time, ROUND(s.altitude_m::numeric,1) AS \"Elevation (m)\" FROM activity_streams s JOIN activities a ON a.id = s.activity_id WHERE s.activity_id = ${activity_id} AND s.altitude_m IS NOT NULL ORDER BY time;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"lineWidth": 2, "fillOpacity": 0, "spanNulls": false, "pointSize": 3}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Speed (km/h)"},
            "properties": [
              {"id": "unit", "value": "velocitykmh"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#5794F2"}},
              {"id": "custom.axisPlacement", "value": "left"},
              {"id": "custom.axisLabel", "value": "Speed (km/h)"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Elevation (m)"},
            "properties": [
              {"id": "unit", "value": "lengthm"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#73BF69"}},
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "custom.axisLabel", "value": "Elevation (m)"},
              {"id": "custom.fillOpacity", "value": 25},
              {"id": "custom.lineWidth", "value": 1}
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "title": "Heart Rate & Power",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 14},
      "datasource": {"type": "postgres", "uid": "veloai"},
      "targets": [
        {
          "rawSql": "SELECT a.date + (s.time_offset * interval '1 second') AS time, s.hr AS \"HR (bpm)\" FROM activity_streams s JOIN activities a ON a.id = s.activity_id WHERE s.activity_id = ${activity_id} AND s.hr IS NOT NULL ORDER BY time;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT a.date + (s.time_offset * interval '1 second') AS time, s.power AS \"Power (W)\" FROM activity_streams s JOIN activities a ON a.id = s.activity_id WHERE s.activity_id = ${activity_id} AND s.power IS NOT NULL ORDER BY time;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"lineWidth": 2, "fillOpacity": 0, "spanNulls": false}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "HR (bpm)"},
            "properties": [
              {"id": "unit", "value": "bpm"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#F2495C"}},
              {"id": "custom.axisPlacement", "value": "left"},
              {"id": "custom.axisLabel", "value": "Heart Rate (bpm)"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Power (W)"},
            "properties": [
              {"id": "unit", "value": "watt"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#FF9830"}},
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "custom.axisLabel", "value": "Power (W)"}
            ]
          }
        ]
      }
    }
  ]
}
