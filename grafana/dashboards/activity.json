    "list": [
      {
        "name": "activity_id",
        "type": "query",
        "label": "Activity",
        "datasource": {
          "type": "postgres",
          "uid": "veloai"
        },
        "query": "SELECT id AS __value, name || ' (' || TO_CHAR(date, 'YYYY-MM-DD') || ')' AS __text FROM activities ORDER BY date DESC LIMIT 50",
        "refresh": 2,
        "sort": 0,
        "current": {},
        "options": []
      },
      {
        "name": "map_metric",
        "type": "custom",
        "label": "Map color",
        "query": "speed_kmh,hr,power",
