      },
      "targets": [
        {
          "rawSql": "WITH deltas AS (\n  SELECT\n    time_offset, hr,\n    power,\n    COALESCE(speed_kmh, 0) / 3600.0 *\n      (time_offset - LAG(time_offset, 1, time_offset) OVER (ORDER BY time_offset)) AS dist_delta\n  FROM activity_streams\n  WHERE activity_id = ${activity_id}\n)\nSELECT\n  ROUND(SUM(dist_delta) OVER (ORDER BY time_offset ROWS UNBOUNDED PRECEDING)::numeric, 2) AS \"Distance (km)\",\n  hr AS \"HR (bpm)\",\n  power AS \"Power (W)\"\nFROM deltas\nORDER BY 1;",
