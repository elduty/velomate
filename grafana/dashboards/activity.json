              "rawSql": "WITH rolling AS (SELECT AVG(power) OVER (ORDER BY time_offset RANGE BETWEEN 299 PRECEDING AND CURRENT ROW) AS avg_5min, AVG(power) OVER (ORDER BY time_offset RANGE BETWEEN 1199 PRECEDING AND CURRENT ROW) AS avg_20min FROM activity_streams WHERE activity_id = ${activity_id} AND power IS NOT NULL AND power > 0) SELECT ROUND(MAX(avg_5min)::numeric, 0) AS \"Best 5min (W)\", ROUND(MAX(avg_20min)::numeric, 0) AS \"Best 20min (W)\" FROM rolling;",
